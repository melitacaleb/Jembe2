<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#2e7d32</item>
        <item name="colorPrimaryDark">#0d0d0d</item>
        <item name="colorAccent">#4caf50</item>
        <item name="android:windowBackground">#0d0d0d</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0d0d0d</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">1800</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
        <item name="android:windowBackground">#0d0d0d</item>
        <item name="android:statusBarColor">#0d0d0d</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#0d0d0d</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
